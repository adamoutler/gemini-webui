{
  "mcpServers": {
    "kanban": {
      "url": "https://kanban.hackedyour.info/mcp/http/api-key/mcp",
      "headers": {
        "Authorization": "Bearer ${KANBAN_API_KEY}",
        "X-Workspace-slug": "gemwebui"
      }
    }
  },
  "general": {
    "plan": {
      "directory": "plans"
    }
  },
  "ui": {
    "inlineThinkingMode": "full"
  },
  "agents": {
    "overrides": {
      "quality_control_agent": {
        "enabled": false
      },
      "kanban_executor": {
        "enabled": false
      }
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "name": "qa-gate-check",
            "type": "command",
            "command": "./.gemini/hooks/qa-gate.sh",
            "description": "Intercepts AI commits to run tests and reality-checker before allowing."
          },
          {
            "name": "git-push-intercept",
            "type": "command",
            "command": "./.gemini/hooks/git-push-intercept.sh",
            "description": "Automatically appends receipt wait to git push"
          }
        ]
      }
    ]
  }
}
