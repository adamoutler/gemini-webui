{
  "mcpServers": {
    "kanban": {
      "url": "https://kanban.hackedyour.info/mcp/http/api-key/mcp",
      "headers": {
        "Authorization": "Bearer ${KANBAN_API_KEY}",
        "X-Workspace-slug": "gemwebui"
      }
    }
  },
  "general": {
    "plan": {
      "directory": "plans"
    }
  },
  "ui": {
    "inlineThinkingMode": "full"
  },
  "agents": {
    "overrides": {
      "quality_control_agent": {
        "enabled": false
      },
      "kanban_executor": {
        "enabled": false
      }
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": ".*(run_shell_command|Bash|shell).*",
        "hooks": [
          {
            "name": "git-push-intercept",
            "type": "command",
            "command": "./.gemini/hooks/git-push-intercept.sh",
            "description": "Automatically appends receipt wait to git push"
          },
          {
            "name": "prevent-curl-bypass",
            "type": "command",
            "command": "./.gemini/hooks/prevent-curl-bypass.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__kanban__update_work_item",
        "hooks": [
          {
            "name": "qa-gate",
            "type": "command",
            "command": "./.gemini/hooks/qa-gate.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "mcp__kanban__create_work_item_comment",
        "hooks": [
          {
            "name": "comment-gate",
            "type": "command",
            "command": "./.gemini/hooks/comment-gate.sh",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}
