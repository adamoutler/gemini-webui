{
  "tools": {
    "shell": {
      "inactivityTimeout": 800
    }
  },
  "mcpServers": {
    "kanban": {
      "url": "https://kanban.hackedyour.info/mcp/agent/api-key/mcp",
      "headers": {
        "Authorization": "Bearer ${KANBAN_API_KEY}",
        "X-Workspace-slug": "gemwebui"
      }
    }
  },
  "general": {
    "plan": {
      "directory": "plans"
    }
  },
  "ui": {
    "inlineThinkingMode": "full"
  },
  "agents": {
    "overrides": {
      "quality_control_agent": {
        "enabled": false
      },
      "kanban_executor": {
        "enabled": false
      }
    }
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": ".*(run_shell_command|Bash|shell|mcp_kanban).*",
        "hooks": [
          {
            "name": "qa-gate",
            "type": "command",
            "command": "./.gemini/hooks/qa-gate.sh",
            "description": "Prevents the AI Orchestrator from directly closing tickets to enforce the verification pipeline.",
            "timeout": 180000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*(run_shell_command|Bash|shell).*",
        "hooks": [
          {
            "name": "git-push-after",
            "type": "command",
            "command": "./.gemini/hooks/git-push-after.sh",
            "description": "Automatically watches GitHub Actions workflows after a git push",
            "timeout": 600000
          }
        ]
      }
    ]
  }
}
