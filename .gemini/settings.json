{
  "tools": {
    "shell": {
      "inactivityTimeout": 800
    }
  },
  "mcpServers": {
    "kanban": {
      "url": "https://kanban.hackedyour.info/mcp/agent/api-key/mcp",
      "headers": {
        "Authorization": "Bearer ${KANBAN_API_KEY}",
        "X-Workspace-slug": "gemwebui"
      }
    }
  },
  "general": {
    "plan": {
      "directory": "plans"
    }
  },
  "ui": {
    "inlineThinkingMode": "full"
  },
  "agents": {
    "overrides": {
      "quality_control_agent": {
        "enabled": false
      },
      "kanban_executor": {
        "enabled": false
      }
    }
  },
  "hooksConfig": {
    "enabled": true,
    "disabled": []
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": ".*(complete_work|transition_ticket).*",
        "hooks": [
          {
            "name": "qa-gate",
            "type": "command",
            "command": "python3 ${GEMINI_PROJECT_DIR}/.gemini/hooks/qa-gate.py",
            "description": "The QA Gate checks all files are committed, all commits are pushed, abd CI has passed. If the checks pass then an independed reality-checker AI QA audit is conducted within the QA Gate",
            "timeout": 1200000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "name": "git push after",
            "type": "command",
            "command": "${GEMINI_PROJECT_DIR}/.gemini/hooks/git-push-after.sh",
            "description": "The git after push provides feedback on the build status after push",
            "timeout": 3000000
          }
        ]
      }
    ],
    "AfterAgent": [
       {
        "hooks": [
          {
            "type": "command",
            "command": "${GEMINI_PROJECT_DIR}/.gemini/hooks/check-ci.sh",
            "name": "ci-check"
          }
        ]
      }
    ]
  }
}
