#!/usr/bin/env python3
import sys
import os
import json

data_dir = os.environ.get("DATA_DIR", ".")
work_dir = os.path.join(data_dir, "workspace") if data_dir != "." else "."
if not os.path.exists(work_dir) and work_dir != ".":
    try:
        os.makedirs(work_dir, exist_ok=True)
    except Exception:
        work_dir = "."

STATE_FILE = os.path.join(work_dir, "gemini_mock_state.json")
SESSIONS_FILE = os.path.join(work_dir, "gemini_mock_sessions.json")


def get_sessions():
    if os.path.exists(SESSIONS_FILE):
        try:
            with open(SESSIONS_FILE, "r") as f:
                return json.load(f)
        except Exception:
            pass
    return [1]


if "--list-sessions" in sys.argv:
    sessions = get_sessions()
    print(f"Available sessions for this project ({len(sessions)}):")
    for sid in sessions:
        # Check for a saved UUID for this session ID
        uuid_file = os.path.join(work_dir, f"gemini_mock_uuid_{sid}.json")
        if os.path.exists(uuid_file):
            with open(uuid_file, "r") as f:
                saved_uuid = f.read().strip()
        else:
            saved_uuid = f"mock-uuid-{sid}"
        print(f"  {sid}. Mock Session (Just now) [{saved_uuid}]")
    sys.exit(0)

# Simulate session creation if not resuming or if resuming a 'new' session
is_new_session = "-r" not in sys.argv or ("-r" in sys.argv and "new" in sys.argv)
print(f"DEBUG MOCK ARGV: {sys.argv}, is_new={is_new_session}", file=sys.stderr)
if is_new_session and "--list-sessions" not in sys.argv:
    sessions = get_sessions()
    new_id = max(sessions) + 1 if sessions else 1
    sessions.append(new_id)
    with open(SESSIONS_FILE, "w") as f:
        json.dump(sessions, f)
    # Save the UUID if provided
    harness_id = os.environ.get("GEMINI_WEBUI_HARNESS_ID")
    print(f"DEBUG MOCK HARNESS: harness_id={harness_id!r}", file=sys.stderr)
    if not harness_id:
        # Fallback to looking in args if passed differently
        pass
    if harness_id:
        uuid_file = os.path.join(work_dir, f"gemini_mock_uuid_{new_id}.json")
        with open(uuid_file, "w") as f:
            f.write(harness_id)


print(
    "Welcome to Fake \x1b[38;5;33mG\x1b[38;5;39me\x1b[38;5;45mm\x1b[38;5;51mi\x1b[38;5;87mn\x1b[38;5;123mi\x1b[0m"
)
sys.stdout.flush()

memory = {}

if "-r" in sys.argv:
    if os.path.exists(STATE_FILE):
        try:
            with open(STATE_FILE, "r") as f:
                memory = json.load(f)
        except (json.JSONDecodeError, OSError) as e:
            print(f"Mock error loading state: {e}", file=sys.stderr)
else:
    # Fresh start, clear state
    if os.path.exists(STATE_FILE):
        os.remove(STATE_FILE)

while True:
    line = sys.stdin.readline()
    if not line:
        break

    if "\x1b" in line:
        print(f"ALT_ENTER_RECEIVED: {repr(line)}")
        sys.stdout.flush()

    line = line.strip()

    if "Remember this TEST_VALUE:" in line:
        val = line.split(":")[-1].strip()
        memory["TEST_VALUE"] = val
        with open(STATE_FILE, "w") as f:
            json.dump(memory, f)
        print(f"I will remember TEST_VALUE: {val}")
        sys.stdout.flush()
    elif (
        "What is the TEST_VALUE" in line
        or "What was the TEST_VALUE" in line
        or "Do you still remember the TEST_VALUE" in line
    ):
        if "TEST_VALUE" in memory:
            print(f"The TEST_VALUE is {memory['TEST_VALUE']}")
        else:
            print("I don't know the TEST_VALUE.")
        sys.stdout.flush()
    else:
        print(f"You said: {line}")
        sys.stdout.flush()
